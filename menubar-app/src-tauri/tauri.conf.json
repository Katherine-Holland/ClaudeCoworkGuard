{
  "productName": "CoworkGuard",
  "version": "1.0.0",
  "identifier": "com.coworkguard.menubar",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "CoworkGuard",
        "width": 400,
        "height": 600,
        "resizable": true,
        "visible": false,
        "decorations": true,
        "alwaysOnTop": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "copyright": "© 2026 Katherine Holland",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "CoworkGuard monitors outbound requests to AI agent APIs and blocks sensitive data before it leaves your machine.",
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "entitlements": null
    },
    "resources": {
      "../../scanner.py": "scanner.py",
      "../../proxy.py": "proxy.py",
      "../../server.py": "server.py",
      "../../dashboard.html": "dashboard.html",
      "../../domains.json": "domains.json"
    },
    "shortDescription": "Privacy protection for AI agents",
    "targets": "all"
  }
}
