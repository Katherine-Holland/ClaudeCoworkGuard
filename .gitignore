# CoworkGuard .gitignore

# Build artifacts — never commit these
chrome-extension.zip
*.zip
*.tar.gz

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Certificates — generated locally, never commit private keys
*.key
*.p12
coworkguard-ca-key.pem

# Local runtime files
.coworkguard/
*.log

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo

# Environment
.env
.env.local
